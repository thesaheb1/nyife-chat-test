# ==================================
# Nyife Environment Variables
# ==================================
# Copy this file to .env and fill in the values.
# All secrets MUST be changed for production.

# ─── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
PUBLIC_FRONTEND_URL=https://app.example.com
EMAIL_SERVICE_URL=http://localhost:3013

# ─── MySQL Database ──────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=nyife_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=nyife_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_change_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Local Admin Seed (optional, for development) ────────────────────────────
ADMIN_SEED_EMAIL=admin@nyife.com
ADMIN_SEED_PASSWORD=Admin123!@#
ADMIN_SEED_FIRST_NAME=Super
ADMIN_SEED_LAST_NAME=Admin
ADMIN_SEED_PHONE=

# ─── Meta WhatsApp Cloud API ─────────────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_SYSTEM_USER_ACCESS_TOKEN=your_meta_system_user_access_token
META_WEBHOOK_VERIFY_TOKEN=202509290511167caQ
META_API_VERSION=v20.0

# ─── Razorpay (Payment Gateway) ──────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── SMTP (Email) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=Nyife
SMTP_FROM_EMAIL=your_email@example.com

# ─── Encryption (AES-256) ────────────────────────────────────────────────────
ENCRYPTION_KEY=your_32_char_encryption_key_here
ENCRYPTION_IV=your_16_char_iv_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Service Ports ────────────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
SUBSCRIPTION_SERVICE_PORT=3003
WALLET_SERVICE_PORT=3004
CONTACT_SERVICE_PORT=3005
TEMPLATE_SERVICE_PORT=3006
CAMPAIGN_SERVICE_PORT=3007
CHAT_SERVICE_PORT=3008
WHATSAPP_SERVICE_PORT=3009
AUTOMATION_SERVICE_PORT=3010
ORGANIZATION_SERVICE_PORT=3011
NOTIFICATION_SERVICE_PORT=3012
EMAIL_SERVICE_PORT=3013
SUPPORT_SERVICE_PORT=3014
ADMIN_SERVICE_PORT=3015
ANALYTICS_SERVICE_PORT=3016
MEDIA_SERVICE_PORT=3017

# ─── OAuth (optional — leave empty to disable) ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
