{
  "name": "nyife",
  "version": "1.0.0",
  "description": "Multi-tenant WhatsApp Marketing SaaS Platform",
  "private": true,
  "workspaces": [
    "shared/*",
    "services/*"
  ],
  "scripts": {
    "stack:up": "node scripts/manage.js stack up",
    "stack:up:build": "node scripts/manage.js stack up --build",
    "stack:stop": "node scripts/manage.js stack stop",
    "stack:down": "node scripts/manage.js stack down",
    "stack:restart": "node scripts/manage.js stack restart",
    "stack:ps": "node scripts/manage.js stack ps",
    "stack:logs": "node scripts/manage.js stack logs",
    "infra:up": "node scripts/manage.js infra up",
    "infra:stop": "node scripts/manage.js infra stop",
    "infra:down": "node scripts/manage.js infra down",
    "infra:restart": "node scripts/manage.js infra restart",
    "service:start": "node scripts/manage.js service start",
    "service:stop": "node scripts/manage.js service stop",
    "service:restart": "node scripts/manage.js service restart",
    "service:logs": "node scripts/manage.js service logs",
    "migrate": "node scripts/manage.js migrate service",
    "migrate:all": "node scripts/manage.js migrate all",
    "migrate:undo": "node scripts/manage.js migrate undo",
    "migrate:status": "node scripts/manage.js migrate status",
    "kafka:setup": "node scripts/manage.js kafka setup",
    "docker:dev": "node scripts/manage.js stack up",
    "docker:dev:build": "node scripts/manage.js stack up --build",
    "docker:dev:down": "node scripts/manage.js stack down",
    "docker:prod": "docker compose up",
    "docker:prod:build": "docker compose up --build",
    "test": "bash scripts/test-all.sh"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "UNLICENSED"
}
