# -------------------------------------------------------
# API Gateway — Environment Variables
# -------------------------------------------------------

# Server
API_GATEWAY_PORT=3000
NODE_ENV=development

# JWT — must match the auth-service secrets
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -------------------------------------------------------
# Internal Service URLs
# In Docker, replace "localhost" with the Docker service name.
# -------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
SUBSCRIPTION_SERVICE_URL=http://localhost:3003
WALLET_SERVICE_URL=http://localhost:3004
CONTACT_SERVICE_URL=http://localhost:3005
TEMPLATE_SERVICE_URL=http://localhost:3006
CAMPAIGN_SERVICE_URL=http://localhost:3007
CHAT_SERVICE_URL=http://localhost:3008
WHATSAPP_SERVICE_URL=http://localhost:3009
AUTOMATION_SERVICE_URL=http://localhost:3010
ORGANIZATION_SERVICE_URL=http://localhost:3011
NOTIFICATION_SERVICE_URL=http://localhost:3012
EMAIL_SERVICE_URL=http://localhost:3013
SUPPORT_SERVICE_URL=http://localhost:3014
ADMIN_SERVICE_URL=http://localhost:3015
ANALYTICS_SERVICE_URL=http://localhost:3016
MEDIA_SERVICE_URL=http://localhost:3017
