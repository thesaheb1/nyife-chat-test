NODE_ENV=development
AUTH_SERVICE_PORT=3001

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=nyife_user
MYSQL_PASSWORD=nyife_pass
MYSQL_DATABASE=nyife_db

REDIS_HOST=localhost
REDIS_PORT=6379
