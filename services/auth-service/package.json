{
  "name": "@nyife/auth-service",
  "version": "1.0.0",
  "description": "Authentication service for Nyife platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:admin": "npx sequelize-cli db:seed --seed src/seeders/20260318000000-seed-admin-account.js"
  },
  "dependencies": {
    "@nyife/shared-config": "1.0.0",
    "@nyife/shared-events": "1.0.0",
    "@nyife/shared-middleware": "1.0.0",
    "@nyife/shared-utils": "1.0.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "morgan": "^1.10.0",
    "mysql2": "^3.19.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "sequelize": "^6.37.8",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.5"
  },
  "license": "UNLICENSED"
}
