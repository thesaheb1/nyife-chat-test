NODE_ENV=development
MEDIA_SERVICE_PORT=3017

# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=nyife_user
MYSQL_PASSWORD=nyife_pass
MYSQL_DATABASE=nyife_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS
CORS_ORIGINS=http://localhost:5173

# Encryption (for internal calls)
ENCRYPTION_KEY=
ENCRYPTION_IV=

# Meta WhatsApp Cloud API
META_API_VERSION=v20.0
META_API_BASE_URL=https://graph.facebook.com/v20.0

# Upload limits (bytes)
MAX_IMAGE_SIZE=5242880
MAX_VIDEO_SIZE=16777216
MAX_AUDIO_SIZE=16777216
MAX_DOCUMENT_SIZE=104857600
