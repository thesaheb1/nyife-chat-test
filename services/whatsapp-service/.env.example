# WhatsApp Service Configuration
NODE_ENV=development
WHATSAPP_SERVICE_PORT=3009

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=nyife_user
MYSQL_PASSWORD=nyife_pass
MYSQL_DATABASE=nyife_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092

# Meta WhatsApp Cloud API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v20.0
META_API_BASE_URL=https://graph.facebook.com/v20.0
META_WEBHOOK_VERIFY_TOKEN=202509290511167caQ

# Optional advanced provider/BSP mode only.
# Leave these unset for the standard Embedded Signup flow used by customers.
# META_SYSTEM_USER_ACCESS_TOKEN=
# META_SYSTEM_USER_ID=
# META_PROVIDER_BUSINESS_ID=
# META_OVERRIDE_CALLBACK_URL=
# META_ENABLE_CREDIT_SHARING=false
# META_CREDIT_LINE_ID=
# META_CREDIT_LINE_CURRENCY=INR
# META_ALLOW_LEGACY_ACCOUNT_TOKEN_FALLBACK=true
# META_REQUIRE_REDIS_FOR_SIGNUP=false

# Encryption (AES-256)
ENCRYPTION_KEY=your_64_hex_char_encryption_key_here_1234567890abcdef1234567890abcdef
ENCRYPTION_IV=your_32_hex_char_iv_here_1234567890abcdef

# JWT (for auth middleware validation)
JWT_SECRET=your_jwt_secret

# Inter-service URLs
SUBSCRIPTION_SERVICE_URL=http://localhost:3003
WALLET_SERVICE_URL=http://localhost:3004
TEMPLATE_SERVICE_URL=http://localhost:3006

# CORS
CORS_ORIGINS=http://localhost:5173
